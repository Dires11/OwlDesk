generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StudentStatus {
  ACTIVE
  PAUSED
  LEAD
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PAID
  PENDING
  UNPAID
  OVERDUE
}

model Student {
  id          String        @id @default(cuid())
  name        String
  grade       String
  email       String        @unique
  subjects    String[]
  status      StudentStatus @default(ACTIVE)
  clerkUserId String?
  createdAt   DateTime      @default(now())
  sessions    Session[]
}

model Tutor {
  id          String    @id @default(cuid())
  name        String
  subjects    String[]
  ratePerHr   Decimal   @db.Decimal(10, 2)
  email       String    @unique
  clerkUserId String?
  createdAt   DateTime  @default(now())
  sessions    Session[]
}

model Session {
  id         String        @id @default(cuid())
  studentId  String
  tutorId    String
  subject    String
  date       DateTime
  duration   Int
  status     SessionStatus @default(SCHEDULED)
  clerkUserId String?
  createdAt  DateTime      @default(now())
  student    Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tutor      Tutor         @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  payment    Payment?

  @@index([date])
  @@index([studentId])
  @@index([tutorId])
}

model Payment {
  id          String        @id @default(cuid())
  sessionId   String        @unique
  amount      Decimal       @db.Decimal(10, 2)
  status      PaymentStatus @default(PENDING)
  dueDate     DateTime
  clerkUserId String?
  createdAt   DateTime      @default(now())
  session     Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([dueDate])
}
